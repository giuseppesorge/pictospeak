<?xml version="1.0" encoding="utf-8"?>
<!-- Dark base window theme. Selected automatically when the system is in dark mode, so the
     pre-Compose window background matches the dark Compose surface (no light flash). -->
<resources>
    <style name="Theme.PictoSpeak" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/window_background</item>
    </style>
</resources>
